# ── Streamlit Secrets ひな形 ─────────────────────────────
# これは「例」です。実際の値を入れたものを Streamlit Cloud の
#   App → Settings → Secrets 画面に貼り付けます（GitHubには載せません）。
# ローカルで試すときは、このファイルを secrets.toml にコピーして値を入れます。
#   ※ secrets.toml は .gitignore 済み（コミットされません）

# 1) ログインパスワード（公開URLを守る・必須）
app_password = "ここに好きなパスワード"

# 2) クラウドDB（Turso/libSQL）
TURSO_DATABASE_URL = "libsql://your-db-xxxx.turso.io"
TURSO_AUTH_TOKEN = "ここにTursoのトークン"

# 3) カレンダー・メール設定（.env と同じ値）
GOOGLE_CALENDAR_IDS = "primary"
# 自分の所属ドメイン（カンマ区切り）。所属を公開コードに書かないため設定で渡す。
UNIVERSITY_EMAIL_DOMAINS = "example-univ1.ac.jp,example-univ2.ac.jp"
# 病院🏥/大学院🎓バッジを出したい場合のみ（任意）。自分のドメインに置き換える。
HOSPITAL_EMAIL_DOMAIN = "example-hospital.ac.jp"
GRAD_EMAIL_DOMAIN = "example-grad.ac.jp"

# 4) （任意）Claude APIで下書きする場合のみ
# ANTHROPIC_API_KEY = "sk-ant-..."

# 5) Google認証（credentials.json / token.json の中身を文字列で丸ごと貼る）
#    三連引用符 """ ... """ の中に、ファイルのJSONをそのまま貼り付けます。
google_credentials_json = """
{ "installed": { "client_id": "...", "client_secret": "...", "redirect_uris": ["..."] } }
"""

google_token_json = """
{ "token": "...", "refresh_token": "...", "client_id": "...", "client_secret": "...", "scopes": ["..."] }
"""
